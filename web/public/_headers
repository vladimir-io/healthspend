/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*; img-src 'self' data: https://*;
  Access-Control-Allow-Origin: *

# Essential for sql.js-httpvfs range requests
/*.db
  Accept-Ranges: bytes
  Access-Control-Expose-Headers: Content-Range, Content-Length
  Cache-Control: public, max-age=3600, no-transform

/*.wasm
  Content-Type: application/wasm
  Cache-Control: public, max-age=31536000, immutable
