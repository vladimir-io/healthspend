# Healthspend v1.0 .gitignore

# Build outputs
dist/
web/dist/
target/
*.o
*.a
*.so
.cargo/

# Dependencies
node_modules/
.npm/
__pycache__/
*.egg-info/
.venv/
venv/

# Data files
*.csv
*.db
*.db-*
*.db-journal
scraper/*.db*

# EXCEPTION: Audit data is tracked for regulatory compliance
!web/public/audit_data.db
!web/public/favicon.ico

# Temporary/local files
*.log
*.tmp
*.temp
*.pid
.DS_Store
Thumbs.db

# Python cache
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# Environment variables
.env
.env.local
.env.*.local
web/.env
web/.env.local
web/.env.*.local

# OS-specific
.DS_Store
.AppleDouble
.LSOverride

!web/public/visibility/
!web/public/api/v1/
!web/public/sitemap.xml
!web/public/media-brief-2026.html
!web/public/transparency-2026.html
!web/public/transparency-index.html
!web/public/mri-variation-report.html
