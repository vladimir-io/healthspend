# Healthspend — .gitignore
# See docs/CONTRIBUTING.md for local dev setup notes.

# ── Rust build outputs ──────────────────────────────────────────────────────
target/
*.o
*.a
*.so
.cargo/

# ── Node / Web ──────────────────────────────────────────────────────────────
node_modules/
.npm/
web/dist/
dist/

# Node binaries downloaded for CI bootstrapping
node-v*.tar.xz
node-v*/

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/

# ── Database files ──────────────────────────────────────────────────────────
*.db
*.db-*
*.db-journal
*.db-shm
*.db-wal
scraper/*.db*
mrf_temp/

# ── Large data files ─────────────────────────────────────────────────────────
*.csv

# ── Test / scratch scripts ───────────────────────────────────────────────────
test_hf.py
test_hf.js
web/test_query*.mjs

# ── Temporary / logs ─────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
*.pid

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
web/.env
web/.env.local
web/.env.*.local
wrangler.toml

# ── Tracked exceptions ───────────────────────────────────────────────────────
!web/public/favicon.ico
!web/public/og-image.png
!web/public/sitemap.xml
!web/public/index.html
!web/public/_headers
!web/public/media-brief-2026.html
!web/public/transparency-2026.html
!web/public/transparency-index.html
!web/public/mri-variation-report.html
!web/public/state-of-non-compliance-2026.html
!web/public/api/
!web/public/visibility/
!web/public/embed/
!scraper/data/test_*.json
!scraper/data/test_*.csv

